{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/big-pickle",
  "default_agent": "orchestrator",
  "agent": {
    "orchestrator": {
      "description": "Primary orchestration agent that coordinates specialist agents and keeps context compact.",
      "mode": "primary",
      "model": "opencode/big-pickle",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "question": "allow",
        "task": {
          "*": "deny",
          "explore-agent": "allow",
          "code-agent": "allow",
          "review-agent": "allow",
          "qa-agent": "allow",
          "report-agent": "allow"
        },
        "edit": "deny",
        "bash": "ask",
        "webfetch": "allow",
        "todowrite": "allow"
      }
    },
    "explore-agent": {
      "description": "Read-only project exploration agent.",
      "mode": "subagent",
      "model": "opencode/big-pickle",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "deny",
        "bash": "ask",
        "webfetch": "allow"
      }
    },
    "code-agent": {
      "description": "Implementation agent for scoped code changes.",
      "mode": "subagent",
      "model": "opencode/big-pickle",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "allow",
        "bash": "ask",
        "webfetch": "allow"
      }
    },
    "review-agent": {
      "description": "Code and architecture review agent with no edit permissions.",
      "mode": "subagent",
      "model": "opencode/big-pickle",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "deny",
        "bash": "ask",
        "webfetch": "allow"
      }
    },
    "qa-agent": {
      "description": "Report-only QA agent for validation and regression assessment.",
      "mode": "subagent",
      "model": "opencode/big-pickle",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "deny",
        "bash": "ask",
        "webfetch": "allow"
      }
    },
    "report-agent": {
      "description": "Weekly reporting agent for Jira and Notion drafts.",
      "mode": "subagent",
      "model": "opencode/big-pickle",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "deny",
        "bash": "ask",
        "webfetch": "allow"
      }
    }
  }
}
